<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns:m="sap.m" xmlns:macros="sap.fe.macros"
		xmlns="sap.suite.ui.microchart"
		xmlns:mvc="sap.ui.core.mvc"
		xmlns:l="sap.ui.layout">
	<m:VBox core:require="{ handler: 'rama/mngpo/ui/managepocapm/ext/fragment/Custom_section'}">
		<m:Button text="Custom_section" press="handler.onPress" />

<l:VerticalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="L" total="360" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="8" color="Good" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="63.5" color="Good" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="S" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="63.5" color="Good" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="XS" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="63.5" color="Good" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="L" total="360" totalScale="Mrd" colorPalette="Sequence1" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="352" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" colorPalette="Sequence1" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="20" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="S" total="100" totalScale="Mrd" colorPalette="Sequence1" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="20" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="XS" total="100" totalScale="Mrd" colorPalette="Sequence1" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="20" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="L" total="360" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="400" color="Error" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="15" color="Error" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="S" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="15" color="Error" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="XS" total="100" totalScale="Mrd" press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="15" color="Error" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="L" total="100" totalScale="Mrd" showTotal="true" showFractions="false"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Critical" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" showTotal="true" showFractions="false"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Critical" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="S" total="100" totalScale="Mrd" showTotal="true" showFractions="false"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Critical" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="XS" total="100" totalScale="Mrd" showTotal="true" showFractions="false"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Critical" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="L" total="100" totalScale="Mrd" showTotal="false" showFractions="true"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Neutral" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" showTotal="false" showFractions="true"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Neutral" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="S" total="100" totalScale="Mrd" showTotal="false" showFractions="true"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Neutral" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
			<HarveyBallMicroChart size="XS" total="100" totalScale="Mrd" showTotal="false" showFractions="true"
								  press=".press">
				<items>
					<HarveyBallMicroChartItem fraction="85" color="Neutral" fractionScale="Mrd"/>
				</items>
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
		<l:HorizontalLayout>
			<HarveyBallMicroChart size="M" total="100" totalScale="Mrd" showTotal="false" showFractions="false" press=".press">
			</HarveyBallMicroChart>
		</l:HorizontalLayout>
	</l:VerticalLayout>

	</m:VBox>
</core:FragmentDefinition>